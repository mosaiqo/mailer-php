{
    "name": "mosaiqo/mailer-php",
    "description": "Official PHP SDK for the Mailer REST API v1.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mosaiqo/mailer-php",
    "keywords": [
        "mailer",
        "email",
        "sdk",
        "api",
        "transactional"
    ],
    "support": {
        "issues": "https://github.com/mosaiqo/mailer-php/issues",
        "source": "https://github.com/mosaiqo/mailer-php"
    },
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7"
    },
    "require-dev": {
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "illuminate/mail": "^11.0||^12.0||^13.0",
        "illuminate/notifications": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "phpunit/phpunit": "^11.0||^12.0",
        "symfony/mailer": "^7.0"
    },
    "suggest": {
        "laravel/framework": "Required only for the Laravel integration (mail transport, notification channel, facade) — ^11.0||^12.0||^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mailer\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mailer\\Sdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mailer\\Sdk\\Laravel\\MailerServiceProvider"
            ],
            "aliases": {
                "Mailer": "Mailer\\Sdk\\Laravel\\Facades\\Mailer"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
